  echo -e "${WHITE}📦    Phiên bản: 4.66${NC}"
  echo -e "${WHITE}⚠️ Bản Cập Nhật: 25-05-2026${NC}"

  echo -e "${BLUE}────────────────────────────${NC}"
  echo ""
  echo -e "${MAGENTA}📺 HƯỚNG DẪN KẾT NỐI TIVI${NC}"
  echo -e "${CYAN}🎮 Điều khiển:${NC} Nhấn ${YELLOW}↑ lên trên cùng${NC} → vào ${WHITE}Cài đặt ⚙${NC}"
  echo -e "${CYAN}🌐 Ngôn ngữ:${NC} Nhấn ${YELLOW}↓ 4 lần${NC} → Language → ${GREEN}English${NC}"
  echo -e "${CYAN}🔓 Developer:${NC} Vào ${WHITE}About${NC} → chọn ${YELLOW}Model${NC} → ${GREEN}OK 9 lần${NC}"
  echo -e "${CYAN}⛔ Lưu ý:${NC} Tắt ${RED}Update tự động${NC}"
  echo -e "${CYAN}⚙️ Quyền:${NC} Account - Security → Bật ${GREEN}ADB Debugging${NC} + ${GREEN}Unknown sources${NC}"
  echo -e "${CYAN}📶 Kết nối:${NC} Bật ${WHITE}WiFi${NC} - Lấy địa chỉ IP : ${ip} $ANDROID"
  echo ""
  echo -e "${BLUE}────────────────────────────${NC}"

  echo -e "${RED}⏻ 0. Thoát${NC}"
  echo ""
  echo -e "${GREEN}🚀 Sẵn sàng kết nối...${NC}"
}

banner_menu2() {
  print_ui() {
  PCT=$((STEP * 100 / TOTAL_STEPS))
  [ $PCT -lt 0 ] && PCT=0
  [ $PCT -gt 100 ] && PCT=100

  FILLED=$((BAR_WIDTH * STEP / TOTAL_STEPS))
  [ $FILLED -lt 0 ] && FILLED=0
  [ $FILLED -gt $BAR_WIDTH ] && FILLED=$BAR_WIDTH

  BAR=""
  for ((i=1;i<=BAR_WIDTH;i++)); do
    if [ $i -le $FILLED ]; then
      BAR="${BAR}█"
    else
      BAR="${BAR}░"
    fi
  done

  clear
  echo -e "${GREEN}=======================================${NC}"
  echo -e "${GREEN}🚀 CÔNG CỤ CÀI ĐẶT TIVI XIAOMI TỰ ĐỘNG V5${NC}"
  echo -e "${WHITE}👨‍💻 Khánh IT - 0967.341.608 - 4.66${NC}"
  echo -e "${GREEN}---------------------------------------${NC}"

  echo -e "$TV_INFO_LINE"

  echo -e "${C_HDR}╟────────────────────────────────────────────────────╢${RST}"
  echo -e "  ${C_BAR}[ ${C_FILL}${BAR}${RST}${C_BAR} ] ${C_TXT}${PCT}%${RST} ${C_DIM}(Bước ${STEP}/${TOTAL_STEPS})${RST}"
  echo -e "${C_HDR}╚════════════════════════════════════════════════════╝${RST}"
  echo ""
  echo ""
  echo -e "${CYAN}📝  HƯỚNG DẪN SỬ DỤNG${NC}"

  echo -e "${WHITE}👉 Bước 1:${NC} Chọn ${GREEN}1${NC} hoặc ${YELLOW}2${NC} hoặc ${CYAN}9${NC} để tải file"
  echo -e "${WHITE}👉 Bước 2:${NC} Chọn ${BLUE}3${NC} hoặc ${MAGENTA}4${NC} để cài đặt"
  echo -e "${WHITE}👉 Bước 3:${NC} Chọn các chức năng khác nếu cần (mục ${CYAN}5${NC},6,${BLUE}7${NC})"
  echo -e "${WHITE}👉 Bước 4:${NC} Chọn ${RED}8${NC} để khởi động lại TV"

  echo ""
  echo -e "${YELLOW}⚠️ Lưu ý:${NC} Làm đúng thứ tự để tránh lỗi"
  echo -e "${CYAN}=======================================${NC}"

  echo -e "${GREEN}📦 1. Tải file APK Về Điện Thoại (Basic)${NC}"
  echo -e "${YELLOW}⚡ 2. Tải file APK Về Điện Thoại PRO (Speed + UI)${NC}"
  echo -e "${BLUE}📲 3. Cài Projectivy Launcher TV Nội Địa BẢN MỚI${NC}"
  echo -e "${MAGENTA}🎯 4. Cài Projectivy Launcher TV Nội Địa${NC}"
  echo -e "${CYAN}🔐 5. Cấp quyền + kích hoạt Launcher${NC}"
  echo -e "${WHITE}📥 6. Cài APK từ Download điện thoại${NC}"
  echo -e "${BLUE}📤 7. Reset Cứng - XOÁ TOÀN BỘ DỮ LIỆU TIVI${NC}"
  echo -e "${RED}🔄 8. Khởi động lại TV${NC}"
  echo -e "${CYAN}🌐 9. CÀI TIVI V5${NC}"
  echo -e "${YELLOW}↩️  0. Quay lại MENU KẾT NỐI${NC}"

  echo -e "${CYAN}=======================================${NC}"
  echo -e "${C_CYAN} Báo lỗi vui lòng liên hệ:${RST} ${C_ORN}0967.341.608${RST}"
  echo ""
}

tick() {
  STEP=$((STEP+1))
  [ $STEP -gt $TOTAL_STEPS ] && STEP=$TOTAL_STEPS
  print_ui
}

pause() { read -p "⏎ Enter để tiếp..."; }

# ===== THÔNG SỐ TIVI CHẠY TỰ DỘNG KHI KẾT NỐI THÀNH CÔNG =====
get_tv_info() {
  MODEL=$(adb shell getprop ro.product.model | tr -d '\r')
  BRAND=$(adb shell getprop ro.product.brand | tr -d '\r')
  PANEL=$(adb shell getprop ro.boot.mi.panel_size 2>/dev/null | tr -d '\r')
  ANDROID=$(adb shell getprop ro.build.version.release | tr -d '\r')
  PATCH=$(adb shell getprop ro.build.version.security_patch | tr -d '\r')
  BUILD_SHOW=$(adb shell getprop ro.build.version.incremental | tr -d '\r')
  DATE=$(adb shell getprop ro.build.date | tr -d '\r')
  SERIAL=$(adb shell getprop ro.serialno | tr -d '\r')

  # Nếu không có PANEL thì gán mặc định
  [ -z "$PANEL" ] && PANEL="?"

  # ===== TẠO BIẾN TV_INFO_LINE =====
TV_INFO_LINE="${CYAN}📺 Thông Tin Tivi:${NC} $MODEL ${GRAY}|${NC} ${YELLOW}$BRAND${NC} ${GRAY}|${NC} ${GREEN}$PANEL Inch${NC}\n\
${MAGENTA}🤖 Android:${NC} $ANDROID ${GRAY}|${NC} ${BLUE}$BUILD_SHOW${NC} ${GRAY}|${NC} ${RED}$PATCH${NC}\n\
${CYAN}📅 Build Date:${NC} $DATE\n\
${YELLOW}🔢 Serial:${NC} $SERIAL ${GRAY}|${NC} ${GREEN}🌐 IP:${NC} ${ip}:5555"
}


# ===== MENU KẾT NỐI TIVI CONNECT =====
menu_connect() {
  while true; do
    clear
    banner_menu1
    read -e -p $'\e[1;36m👉 Nhập IP: \e[0m' ip
    [ "$ip" = "0" ] && break

    adb connect "$ip:5555" >/dev/null 2>&1
    sleep 8

    if adb devices | grep -q "$ip:5555.*device"; then
      echo -e "${GREEN}✅ KẾT NỐI THÀNH CÔNG!${NC}"
      sleep 3
      get_tv_info
      menu_main
    else
      echo -e "${RED}❌ KẾT NỐI THẤT BẠI!${NC}"
      sleep 2
    fi
  done
}

# ===== MENU 2 =====
menu_main() {
  while true; do
    clear
    banner_menu2
    read -p "👉 Vui Lòng Chọn 0-9: " choice
    case $choice in
      1) download_all ;;
      2) download_all_pro ;;
      3) install_all ;;
      4) projectivy_install ;;
      5) cap_quyen ;;
      6) install_from_phone_download ;;
      7) reboot_recovery ;;
      8) reboot_tv ;;
      9) download_json ;;
      0) return ;;
      *) echo -e "${RED}❌ Sai lựa chọn${NC}"; sleep 1 ;;
    esac
  done
}



