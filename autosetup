#!/bin/bash

# ===== COLOR =====
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
MAGENTA='\033[1;35m'
NC='\033[0m'

BAR_WIDTH=30
TOTAL_STEPS=60
STEP=0
ESC="\033"
RST="${ESC}[0m"
C_HDR="${ESC}[93m"
C_TXT="${ESC}[97m"
C_DIM="${ESC}[90m"
C_BAR="${ESC}[96m"
C_FILL="${ESC}[92m"
C_RED="${ESC}[91m"
C_CYAN="${ESC}[36m"
C_ORN="${ESC}[38;5;202m"


# ===== UI =====
