# ===== DOWNLOAD (GIỮ NGUYÊN) =====
download_all() {
  DIR="$HOME/storage/shared/apktool"
  mkdir -p "$DIR"

  URLS=(
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/allapp.apk"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/file.apk"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/katniss_2.2.0.apk"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/keyboard.apk"
    "https://github.com/khanhitpro/toolxiaomiv3/releases/download/xiaomiv3/p.apk"
    "https://github.com/khanhitpro/XIAOMI/releases/download/khoapp1/khanhstore-6.9.6.apk"
    "https://github.com/khanhitpro/toolxiaomiv3/releases/download/xiaomiv3/projectiv1.plbackup"
    "https://github.com/khanhitpro/toolxiaomiv3/releases/download/xiaomiv3/projectiv2.plbackup"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/youtube.apk"
  )

  echo -e "${CYAN}⬇️ Đang tải toàn bộ file...${NC}"

  for url in "${URLS[@]}"; do
    file="$DIR/$(basename "$url")"
    if wget -q "$url" -O "$file"; then
      echo -e "${GREEN}✅ $(basename "$url")${NC}"
    else
      echo -e "${RED}❌ $(basename "$url")${NC}"
    fi
  done

  pause
}

# ===== DOWNLOAD NHANH HƠN =====
download_all_pro() {
  DIR="$HOME/storage/shared/apktool"
  mkdir -p "$DIR"

  URLS=(
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/allapp.apk"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/file.apk"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/katniss_2.2.0.apk"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/keyboard.apk"
    "https://github.com/khanhitpro/toolxiaomiv3/releases/download/xiaomiv3/p.apk"
    "https://github.com/khanhitpro/XIAOMI/releases/download/khoapp1/khanhstore-6.9.6.apk"
    "https://github.com/khanhitpro/toolxiaomiv3/releases/download/xiaomiv3/projectiv1.plbackup"
    "https://github.com/khanhitpro/toolxiaomiv3/releases/download/xiaomiv3/projectiv2.plbackup"
    "https://github.com/khanhitxiaomi/toolxiaomi/releases/download/toolxiaomi/youtube.apk"
  )

  clear
  echo -e "${CYAN}🚀 DOWNLOAD PRO MAX${NC}"
  echo "---------------------------------------"

  total=${#URLS[@]}
  ok=0
  fail=0
  count=0

  for url in "${URLS[@]}"; do
    file="$DIR/$(basename "$url")"
    ((count++))

    echo -e "${YELLOW}[$count/$total] 📦 $(basename "$url")${NC}"

    # ===== DOWNLOAD =====
    wget -q --show-progress --tries=2 --timeout=10 "$url" -O "$file"

    if [ $? -eq 0 ]; then
      echo -e "${GREEN}   ✅ OK${NC}"
      ((ok++))
    else
      echo -e "${RED}   ❌ FAIL${NC}"
      ((fail++))
    fi

    percent=$((count * 100 / total))
    echo -e "${CYAN}📊 Progress: $percent%${NC}"
    echo "---------------------------------------"
  done

  echo -e "${GREEN}🎉 HOÀN TẤT DOWNLOAD${NC}"
  echo -e "${CYAN}📦 Thành công: $ok | ❌ Lỗi: $fail${NC}"

  pause
}


